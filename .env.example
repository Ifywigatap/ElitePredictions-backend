# ==========================================

# ELITE PREDICTIONS BACKEND ENVIRONMENT VARIABLES

# ==========================================

# Application

NODE_ENV=development
PORT=5000

# Frontend URL

FRONTEND_URL=http://localhost:5173

# Security

JWT_SECRET=your_jwt_secret_here

# ==========================================

# FIREBASE ADMIN SDK

# ==========================================

FIREBASE_PROJECT_ID=your_firebase_project_id

FIREBASE_CLIENT_EMAIL=[firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com](mailto:firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com)

FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ==========================================

# FIREBASE FEATURES

# ==========================================

FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ==========================================

# FOOTBALL DATA API

# ==========================================

FOOTBALL_API_KEY=your_football_api_key

# ==========================================

# PAYSTACK

# ==========================================

PAYSTACK_SECRET_KEY=your_paystack_secret_key

# ==========================================

# OPENAI

# ==========================================

OPENAI_ENABLED=false

OPENAI_API_KEY=your_openai_api_key

OPENAI_MODEL=gpt-4o-mini

# ==========================================

# REDIS (OPTIONAL)

# ==========================================

REDIS_ENABLED=false

REDIS_URL=redis://localhost:6379

# ==========================================

# SENTRY

# ==========================================

SENTRY_ENABLED=false

SENTRY_DSN=your_sentry_dsn

# ==========================================

# SOCKET.IO

# ==========================================

SOCKET_CORS_ORIGIN=http://localhost:5173

# ==========================================

# WEBHOOKS (OPTIONAL)

# ==========================================

PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
